# Neural Ledger — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── LLM ────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Qdrant ─────────────────────────────────────────────────────────
# Leave QDRANT_HOST empty to use local embedded mode (recommended for dev)
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Database ───────────────────────────────────────────────────────
DB_MEMORY_LIMIT=512MB
DB_THREADS=4
QUALITY_GATE_MIN=0.7

# ── Embeddings ─────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=64

# ── API ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# ── Localisation ───────────────────────────────────────────────────
DEFAULT_CURRENCY=PKR
DEFAULT_LANGUAGE=en
TIMEZONE=Asia/Karachi
FISCAL_YEAR_START=07-01